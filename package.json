{
  "name": "excel-ref-navigator",
  "version": "1.0.0",
  "description": "Excel add-in that shows all referenced cells (precedents) for the selected cell with click-to-navigate",
  "main": "src/taskpane.js",
  "scripts": {
    "start": "office-addin-debugging start manifest.xml",
    "start:desktop": "office-addin-debugging start manifest.xml desktop",
    "start:web": "office-addin-debugging start manifest.xml web",
    "stop": "office-addin-debugging stop manifest.xml",
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "sideload": "office-addin-dev-certs install && webpack serve --mode development",
    "validate": "office-addin-manifest validate manifest.xml",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.89"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0"
  }
}
